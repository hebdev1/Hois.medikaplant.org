NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-publishable-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Stripe ────────────────────────────────────────────────────────────────
# Server-only. Test vs live is decided entirely by which key is set — the
# application code is identical. Price IDs differ between the two modes, so
# subscription_plans.stripe_price_id_* must match the key's mode.
STRIPE_SECRET_KEY=sk_test_xxx
# Stripe Dashboard → Developers → Webhooks, for endpoint
# <site>/api/webhooks/stripe. Required — the webhook rejects unsigned calls.
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Safe to expose — it only identifies the account. Needed by the on-page card
# fields (Stripe Elements) in components/checkout/card-payment.tsx.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
